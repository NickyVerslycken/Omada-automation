# EXAMPLE ONLY - DO NOT USE REAL CREDENTIALS IN THIS FILE.
# Key format: OMADA_PROFILE_<PROFILE_ID_UPPERCASE>_<CLIENT_ID|CLIENT_SECRET|OMADAC_ID>
# The <PROFILE_ID_UPPERCASE> token is derived from the profile "id" in controller_profiles.json.

# Profile id: example_profile_alpha_oc200
OMADA_PROFILE_EXAMPLE_PROFILE_ALPHA_OC200_CLIENT_ID=EXAMPLE_ONLY_ALPHA_CLIENT_ID_NOT_REAL
OMADA_PROFILE_EXAMPLE_PROFILE_ALPHA_OC200_CLIENT_SECRET=EXAMPLE_ONLY_ALPHA_CLIENT_SECRET_NOT_REAL
OMADA_PROFILE_EXAMPLE_PROFILE_ALPHA_OC200_OMADAC_ID=EXAMPLE_ONLY_ALPHA_OMADAC_ID_NOT_REAL

# Profile id: example_profile_beta_software_controller
OMADA_PROFILE_EXAMPLE_PROFILE_BETA_SOFTWARE_CONTROLLER_CLIENT_ID=EXAMPLE_ONLY_BETA_CLIENT_ID_NOT_REAL
OMADA_PROFILE_EXAMPLE_PROFILE_BETA_SOFTWARE_CONTROLLER_CLIENT_SECRET=EXAMPLE_ONLY_BETA_CLIENT_SECRET_NOT_REAL
# Optional value for fallback when omadacId auto-detect does not work:
OMADA_PROFILE_EXAMPLE_PROFILE_BETA_SOFTWARE_CONTROLLER_OMADAC_ID=EXAMPLE_ONLY_BETA_OMADAC_ID_NOT_REAL
